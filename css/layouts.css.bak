/**
 * ifans.click — Layouts CSS
 * Estrutura de página, navegação e grade — rede social mobile-first
 * Depende de: tokens.css, base.css
 */

/* ─────────────────────────────────────────────
   1. HEADER — Barra superior fixa
   ───────────────────────────────────────────── */

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  height: 56px;
  isolation: isolate;
}

.header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(var(--color-bg-primary), 0.90);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-bottom: 1px solid var(--color-border-subtle);
  z-index: -1;
  /* Compatibilidade: fallback para cores diretas */
  background: color-mix(in srgb, var(--color-bg-primary) 90%, transparent);
}

/* Fallback explícito para suporte cross-browser */
@supports not (color: color-mix(in srgb, black, white)) {
  .header::before {
    background: rgba(13, 11, 30, 0.90);
  }
}

[data-theme="light"] .header::before,
@media (prefers-color-scheme: light) {
  .header::before {
    background: rgba(255, 255, 255, 0.90);
  }
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-4);
}

.header-logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

.header-logo img {
  height: 32px;
  width: auto;
}

/* Mobile: só símbolo — Desktop: só wordmark */
.header-logo-wordmark {
  display: none;
}

@media (min-width: 768px) {
  .header-logo-symbol {
    display: none;
  }
  .header-logo-wordmark {
    display: block;
  }
}

.header-actions {
  display: flex;
  align-items: center;
  gap: var(--space-2); /* era 4px — WCAG 2.2 mínimo 8px entre targets */
}

/* Créditos / moedas na header */
.header-creditos {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  border-radius: var(--radius-full);
  background: var(--color-bg-tertiary);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border-subtle);
}

@media (min-width: 768px) {
  .header {
    height: 64px;
  }
}

/* ─────────────────────────────────────────────
   2. BOTTOM NAV — Navegação inferior (Instagram style)
   ───────────────────────────────────────────── */

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  /* Sem height fixa — cresce com safe-area-inset-bottom */
  isolation: isolate;
}

.bottom-nav::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(13, 11, 30, 0.95);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-top: 1px solid var(--color-border-subtle);
  z-index: -1;
}

[data-theme="light"] .bottom-nav::before,
@media (prefers-color-scheme: light) {
  .bottom-nav::before {
    background: rgba(255, 255, 255, 0.95);
  }
}

.bottom-nav-inner {
  position: relative;
  display: flex;
  /* Área útil de 56px + safe-area iOS no bottom */
  padding-top: 8px;
  padding-bottom: calc(8px + env(safe-area-inset-bottom, 0px));
}

.bottom-nav-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  min-width: 44px;
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
  color: var(--color-text-tertiary);
  cursor: pointer;
  background: none;
  border: none;
  transition: color var(--transition-fast);
  -webkit-tap-highlight-color: transparent;
}

.bottom-nav-tab.ativo {
  color: var(--color-brand-primary);
}

.bottom-nav-tab img,
.bottom-nav-tab svg {
  width: 24px;
  height: 24px;
}

/* Filtro para ícones inativos */
.bottom-nav-tab:not(.ativo) img {
  filter: brightness(0.5) saturate(0);
}

/* Filtro para ícone ativo — tinta Velvet */
.bottom-nav-tab.ativo img {
  filter: invert(20%) sepia(80%) saturate(1000%) hue-rotate(235deg) brightness(0.85);
}

/* Botão central de criação */
.bottom-nav-tab--criar {
  position: relative;
}

.bottom-nav-tab--criar .criar-btn {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-full);
  background: linear-gradient(
    135deg,
    var(--primitive-desire-500) 0%,
    var(--primitive-desire-700) 100%
  );
  box-shadow: var(--shadow-desire);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 22px;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  border: none;
  cursor: pointer;
}

.bottom-nav-tab--criar .criar-btn:hover {
  box-shadow: 0 8px 28px rgba(253, 41, 108, 0.50);
}

.bottom-nav-tab--criar .criar-btn:active {
  transform: scale(0.9);
}

/* Ocultar bottom nav no desktop (usa sidebar) */
@media (min-width: 768px) {
  .bottom-nav {
    display: none;
  }
}

/* ─────────────────────────────────────────────
   3. ESTRUTURA DE PÁGINA
   ───────────────────────────────────────────── */

.page {
  min-height: 100vh;
}

/* Compensa a header fixa */
.page-with-header {
  padding-top: 56px;
}

@media (min-width: 768px) {
  .page-with-header {
    padding-top: 64px;
  }
}

/* Compensa o bottom nav fixo (56px útil + 8px padding-top + safe-area) */
.page-with-nav {
  padding-bottom: calc(72px + env(safe-area-inset-bottom, 0px));
}

/* Página completa: header + nav */
.page-full {
  padding-top: 56px;
  padding-bottom: calc(72px + env(safe-area-inset-bottom, 0px));
}

@media (min-width: 768px) {
  .page-full {
    padding-top: 64px;
    padding-bottom: 0;
  }
}

/* ─────────────────────────────────────────────
   4. CONTAINERS DE CONTEÚDO
   ───────────────────────────────────────────── */

.content-xs {
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--space-4);
  padding-right: var(--space-4);
}

.content-max {
  max-width: 640px;
  margin-left: auto;
  margin-right: auto;
}

.content-wide {
  max-width: 960px;
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--space-4);
  padding-right: var(--space-4);
}

.content-full {
  max-width: 1280px;
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--space-4);
  padding-right: var(--space-4);
}

/* ─────────────────────────────────────────────
   5. FEED SOCIAL
   ───────────────────────────────────────────── */

.feed-social {
  display: flex;
  flex-direction: column;
  max-width: 470px;
  margin-left: auto;
  margin-right: auto;
}

/* Shell principal — desktop */
.app-shell {
  display: flex;
}

/* Stories strip horizontal */
.stories-strip {
  display: flex;
  overflow-x: auto;
  gap: 12px;
  padding: 12px 16px;
  /* Fix Safari: último item corta sem padding-right explícito no scroll */
  scroll-padding-inline-start: 16px;
  /* Garante que o último item tenha respiro ao final do scroll */
  padding-right: 16px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.stories-strip::-webkit-scrollbar {
  display: none;
}

/* Grade de descoberta */
.discover-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 0 16px;
}

@media (min-width: 640px) {
  .discover-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* Grade de mídia do perfil — 3 colunas sem gap (Instagram) */
.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}

.media-grid-item {
  aspect-ratio: 1 / 1;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  background: var(--color-bg-tertiary);
}

.media-grid-item img,
.media-grid-item video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-std);
}

.media-grid-item:hover img,
.media-grid-item:hover video {
  transform: scale(1.05);
}

.media-grid-locked {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.40);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 18px;
}

/* ─────────────────────────────────────────────
   6. SIDEBAR — Desktop
   ───────────────────────────────────────────── */

.sidebar {
  display: none;
}

@media (min-width: 768px) {
  .sidebar {
    display: flex;
    flex-direction: column;
    width: 244px;
    min-height: 100vh;
    position: sticky;
    top: 0;
    height: 100vh;
    border-right: 1px solid var(--color-border-subtle);
    flex-shrink: 0;
    overflow-y: auto;
    background: var(--color-bg-primary);
  }
}

@media (min-width: 1264px) {
  .sidebar {
    width: 275px;
  }
}

.sidebar-logo {
  padding: 20px 16px;
  display: flex;
  align-items: center;
}

.sidebar-nav {
  flex: 1;
  padding: 8px;
  overflow-y: auto;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 12px 16px;
  border-radius: var(--radius-xl);
  cursor: pointer;
  font-size: var(--text-base);
  color: var(--color-text-secondary);
  background: none;
  border: none;
  width: 100%;
  text-align: left;
  transition:
    background var(--transition-fast),
    color var(--transition-fast);
}

.sidebar-item.ativo {
  background: rgba(68, 42, 192, 0.10);
  color: var(--color-brand-primary);
  font-weight: var(--weight-semibold);
}

.sidebar-item:not(.ativo):hover {
  background: var(--color-bg-tertiary);
  color: var(--color-text-primary);
}

.sidebar-item-icon {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}

/* Botão de criar na sidebar */
.sidebar-criar {
  margin: 8px;
  margin-bottom: 16px;
}

.sidebar-criar .btn {
  width: 100%;
}

.sidebar-footer {
  padding: 16px;
  border-top: 1px solid var(--color-border-subtle);
}

/* ─────────────────────────────────────────────
   7. TOPBAR — Para páginas internas (perfil, DM)
   ───────────────────────────────────────────── */

.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 16px;
  isolation: isolate;
}

.topbar::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: -1;
  background: transparent;
  border-bottom: 1px solid transparent;
  backdrop-filter: blur(0px);
  transition:
    background var(--transition-std),
    backdrop-filter var(--transition-std),
    border-color var(--transition-std);
}

/* Estado após scroll — fundo opaco */
.topbar.rolando::before {
  background: rgba(13, 11, 30, 0.90);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-color: var(--color-border-subtle);
}

[data-theme="light"] .topbar.rolando::before {
  background: rgba(255, 255, 255, 0.90);
}

.topbar-titulo {
  font-family: var(--font-display);
  font-weight: var(--weight-bold);
  font-size: var(--text-lg);
  flex: 1;
  text-align: center;
}

.topbar-back {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.10);
  border: none;
  cursor: pointer;
  color: var(--color-text-primary);
  transition:
    background var(--transition-fast),
    transform var(--transition-fast);
  flex-shrink: 0;
}

.topbar-back:hover {
  background: rgba(255, 255, 255, 0.15);
}

.topbar-back:active {
  transform: scale(0.9);
}

/* ─────────────────────────────────────────────
   8. CABEÇALHOS DE SEÇÃO
   ───────────────────────────────────────────── */

.secao-titulo {
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  color: var(--color-text-secondary);
  padding: 16px 16px 8px;
  text-transform: uppercase;
  letter-spacing: var(--tracking-wider);
}

.secao-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
}

.secao-ver-tudo {
  font-size: var(--text-sm);
  color: var(--color-brand-primary);
  font-weight: var(--weight-medium);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: opacity var(--transition-fast);
}

.secao-ver-tudo:hover {
  opacity: 0.75;
}

/* ─────────────────────────────────────────────
   9. DESKTOP — AJUSTES DO APP SHELL
   ───────────────────────────────────────────── */

@media (min-width: 768px) {
  .app-shell {
    display: flex;
    gap: 0;
    max-width: 1280px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* Sidebar visível — feed ao lado */
  .sidebar {
    display: flex;
  }

  .feed-social {
    margin-left: 0;
    flex: 1;
    max-width: 470px;
  }
}

@media (min-width: 1024px) {
  .feed-social {
    margin-left: var(--space-8);
  }
}
