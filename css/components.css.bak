/**
 * ifans.click — Components CSS
 * Componentes de rede social moderna
 * Depende de: tokens.css, base.css
 */

/* ─────────────────────────────────────────────
   1. BOTÕES
   ───────────────────────────────────────────── */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  min-height: 44px;
  padding: var(--space-2) var(--space-5);
  border-radius: var(--radius-button);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-none);
  text-align: center;
  white-space: nowrap;
  cursor: pointer;
  border: 1px solid transparent;
  transition:
    background var(--transition-fast),
    box-shadow var(--transition-fast),
    transform var(--transition-fast),
    border-color var(--transition-fast),
    opacity var(--transition-fast);
  position: relative;
  overflow: hidden;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}

.btn:active {
  transform: scale(0.97);
}

.btn:disabled,
.btn[aria-disabled="true"] {
  opacity: 0.45;
  pointer-events: none;
}

/* Primário — Velvet */
.btn-primary {
  background: var(--color-action-primary-bg);
  color: var(--color-action-primary-text);
  box-shadow: var(--shadow-velvet);
}

.btn-primary:hover {
  background: var(--color-action-primary-bg-hover);
  box-shadow: 0 8px 28px rgba(68, 42, 192, 0.45);
}

.btn-primary:active {
  background: var(--color-action-primary-bg-active);
}

/* Secundário — Desire gradient */
.btn-secondary {
  background: linear-gradient(
    135deg,
    var(--primitive-desire-500) 0%,
    var(--primitive-desire-700) 100%
  );
  color: var(--color-action-secondary-text);
  box-shadow: var(--shadow-desire);
}

.btn-secondary:hover {
  box-shadow: 0 8px 28px rgba(253, 41, 108, 0.50);
  filter: brightness(1.05);
}

/* Ghost — transparente */
.btn-ghost {
  background: transparent;
  color: var(--color-text-secondary);
  border-color: transparent;
}

.btn-ghost:hover {
  background: rgba(255, 255, 255, 0.05);
  color: var(--color-text-primary);
}

/* Outline — borda visível */
.btn-outline {
  background: transparent;
  color: var(--color-text-primary);
  border-color: var(--color-border-default);
}

.btn-outline:hover {
  border-color: var(--color-border-strong);
  background: rgba(255, 255, 255, 0.03);
}

/* Destrutivo — Desire sólido */
.btn-destructive {
  background: var(--primitive-desire-600);
  color: white;
}

.btn-destructive:hover {
  background: var(--primitive-desire-700);
}

/* Tamanho pequeno */
.btn-sm {
  min-height: 36px;
  padding: var(--space-1) var(--space-4);
  font-size: var(--text-xs);
}

/* Largura total */
.btn-full {
  width: 100%;
}

/* Botão ícone — quadrado arredondado */
.btn-icon {
  width: 44px;
  height: 44px;
  min-height: 44px;
  padding: 0;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

/* Botão flutuante de tema — canto inferior */
.btn-tema {
  position: fixed;
  bottom: 88px;
  right: 16px;
  width: 44px;
  height: 44px;
  min-height: 44px;
  padding: 0;
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-default);
  color: var(--color-text-secondary);
  box-shadow: var(--shadow-md);
  z-index: var(--z-raised);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.btn-tema:hover {
  box-shadow: var(--shadow-lg);
  color: var(--color-text-primary);
}

/* ─────────────────────────────────────────────
   2. AVATAR
   ───────────────────────────────────────────── */

.avatar {
  position: relative;
  border-radius: var(--radius-full);
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--color-brand-primary);
}

.avatar-xs  { width: 24px;  height: 24px; }
.avatar-sm  { width: 32px;  height: 32px; }
.avatar-md  { width: 40px;  height: 40px; }
.avatar-lg  { width: 56px;  height: 56px; }
.avatar-xl  { width: 80px;  height: 80px; }
.avatar-2xl { width: 96px;  height: 96px; }

.avatar-iniciais {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: var(--weight-semibold);
  color: white;
  background: var(--color-brand-primary);
  user-select: none;
  font-size: 0.4em;
}

.avatar-xs  .avatar-iniciais { font-size: 9px; }
.avatar-sm  .avatar-iniciais { font-size: 11px; }
.avatar-md  .avatar-iniciais { font-size: 14px; }
.avatar-lg  .avatar-iniciais { font-size: 18px; }
.avatar-xl  .avatar-iniciais { font-size: 24px; }
.avatar-2xl .avatar-iniciais { font-size: 28px; }

.avatar img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--radius-full);
}

/* Badge de online */
.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 10px;
  height: 10px;
  background: #10B981;
  border-radius: var(--radius-full);
  border: 2px solid var(--color-bg-primary);
}

/* Variantes de anel */
.avatar-ring-creator {
  /* box-shadow segue border-radius — outline não funciona no Safari mobile */
  box-shadow: 0 0 0 2px var(--color-bg-primary), 0 0 0 4px var(--primitive-desire-500);
}

.avatar-ring-premium {
  box-shadow: 0 0 0 2px var(--color-bg-primary), 0 0 0 4px var(--primitive-velvet-500);
}

.avatar-ring-gradient {
  position: relative;
}

.avatar-ring-gradient::before {
  content: '';
  position: absolute;
  inset: -3px;
  border-radius: var(--radius-full);
  background: conic-gradient(
    from 0deg,
    var(--primitive-velvet-500),
    var(--primitive-desire-500),
    var(--primitive-velvet-300),
    var(--primitive-velvet-500)
  );
  z-index: -1;
}

/* ─────────────────────────────────────────────
   3. STORY CIRCLE
   ───────────────────────────────────────────── */

.story-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  flex-shrink: 0;
}

.story-ring {
  padding: 2px;
  border-radius: var(--radius-full);
  background: conic-gradient(
    from 0deg,
    var(--primitive-velvet-500) 0%,
    var(--primitive-desire-500) 50%,
    var(--primitive-velvet-400) 100%
  );
  transition: opacity var(--transition-fast);
}

.story-ring:hover {
  opacity: 0.85;
}

.story-ring-seen {
  background: var(--color-border-default);
}

.story-ring-add {
  background: var(--color-brand-secondary);
}

.story-avatar {
  display: block;
  border-radius: var(--radius-full);
  border: 2px solid var(--color-bg-primary);
}

.story-nome {
  font-size: var(--text-xs);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 64px;
  color: var(--color-text-secondary);
}

/* Story Viewer — fullscreen */
.story-viewer {
  position: fixed;
  inset: 0;
  background: black;
  z-index: calc(var(--z-modal) + 10);
  display: flex;
  flex-direction: column;
}

.story-progress-bar {
  display: flex;
  gap: 4px;
  padding: 12px 12px 0;
}

.story-segment {
  flex: 1;
  height: 2px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.story-segment-fill {
  height: 100%;
  background: white;
  transition: width 0.1s linear;
}

.story-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
}

.story-content {
  flex: 1;
  position: relative;
  overflow: hidden;
}

.story-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.story-zona-left {
  position: absolute;
  top: 0;
  left: 0;
  width: 33.333%;
  height: 100%;
  z-index: 10;
}

.story-zona-right {
  position: absolute;
  top: 0;
  right: 0;
  width: 66.667%;
  height: 100%;
  z-index: 10;
}

.story-footer {
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
  display: flex;
  gap: 8px;
}

.story-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: white;
  border-radius: var(--radius-full);
  padding: 10px 16px;
  font-size: var(--text-sm);
}

.story-input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

/* ─────────────────────────────────────────────
   4. POST CARD (Feed estilo rede social)
   ───────────────────────────────────────────── */

.post-card {
  position: relative;
  background: var(--color-bg-tertiary);
  margin-bottom: 8px;
}

@media (min-width: 768px) {
  .post-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    margin-bottom: 24px;
    overflow: hidden;
  }
}

.post-card-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
}

.post-card-header-info {
  flex: 1;
  min-width: 0;
}

.post-card-nome {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-card-handle {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
}

/* Área de mídia */
.post-card-media {
  position: relative;
  overflow: hidden;
  background: var(--color-bg-tertiary);
  aspect-ratio: 4 / 5; /* padrão portrait — previne CLS ao carregar imagens reais */
}

.post-card-media img,
.post-card-media video {
  width: 100%;
  display: block;
  object-fit: cover;
}

.post-card-media.square   { aspect-ratio: 1 / 1; }
.post-card-media.portrait { aspect-ratio: 4 / 5; }
.post-card-media.wide     { aspect-ratio: 16 / 9; }

/* Overlay de conteúdo bloqueado */
.post-locked-overlay {
  position: absolute;
  inset: 0;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  background: rgba(0, 0, 0, 0.40);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: opacity var(--transition-std);
}

.post-lock-icon {
  width: 48px;
  height: 48px;
  background: rgba(255, 255, 255, 0.10);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  font-size: 20px;
}

.post-locked-preco {
  background: linear-gradient(135deg, var(--primitive-desire-400), var(--primitive-desire-600));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: var(--weight-bold);
  font-size: var(--text-xl);
}

.post-locked-btn {
  margin-top: 12px;
}

/* Ações do post */
.post-actions {
  padding: 4px 16px 8px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.post-action-btn {
  border: none;
  background: none;
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--text-sm);
  cursor: pointer;
  min-height: 44px;
  padding: 0 8px;
  transition: color var(--transition-fast), transform var(--transition-fast);
  -webkit-tap-highlight-color: transparent;
}

.post-action-btn:hover {
  color: var(--color-text-primary);
}

.post-action-btn:active {
  transform: scale(0.9);
}

.post-action-btn.ativo {
  color: var(--primitive-desire-500);
}

.post-action-btn.ativo .post-action-icon {
  filter: invert(30%) sepia(80%) saturate(500%) hue-rotate(300deg) brightness(1.1);
}

/* Botão salvar vai para a direita */
.post-action-salvar {
  margin-left: auto;
}

/* Contagem de curtidas */
.post-contagem {
  padding: 0 16px;
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  margin-bottom: 2px;
}

/* Descrição do post */
.post-descricao {
  padding: 4px 16px 8px;
  font-size: var(--text-sm);
  line-height: var(--leading-relaxed);
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-descricao a {
  color: var(--primitive-velvet-400);
  font-weight: var(--weight-medium);
}

/* Tempo do post */
.post-tempo {
  padding: 0 16px 12px;
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
}

/* ─────────────────────────────────────────────
   5. COMENTÁRIOS
   ───────────────────────────────────────────── */

.comentarios-secao {
  padding: 0 16px;
  border-top: 1px solid var(--color-border-subtle);
  padding-top: 12px;
}

.comentarios-input-row {
  display: flex;
  gap: 8px;
  align-items: center;
  padding: 12px 0;
}

.comentarios-input {
  flex: 1;
  background: var(--color-bg-tertiary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-full);
  padding: 8px 16px;
  font-size: var(--text-sm);
  color: var(--color-text-primary);
  outline: none;
  transition: border-color var(--transition-fast);
}

.comentarios-input:focus {
  border-color: var(--color-border-focus);
  box-shadow: var(--focus-ring);
}

.comentarios-input::placeholder {
  color: var(--color-text-tertiary);
}

.comentario-item {
  display: flex;
  gap: 12px;
  padding: 8px 0;
}

.comentario-item.novo {
  animation: fadeIn var(--motion-sm) var(--ease-decelerate);
}

.comentario-corpo {
  flex: 1;
  min-width: 0;
}

.comentario-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.comentario-tempo {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
}

.comentario-texto {
  font-size: var(--text-sm);
  line-height: var(--leading-relaxed);
}

.comentario-acoes {
  display: flex;
  gap: 16px;
  margin-top: 4px;
}

.btn-comentario-acao {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: color var(--transition-fast);
}

.btn-comentario-acao:hover {
  color: var(--color-text-secondary);
}

.btn-comentario-curtida {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0;
  transition: color var(--transition-fast);
}

.btn-comentario-curtida:hover {
  color: var(--color-text-secondary);
}

.btn-comentario-curtida.ativo {
  color: var(--primitive-desire-500);
}

/* ─────────────────────────────────────────────
   6. BADGES
   ───────────────────────────────────────────── */

.badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-tight);
  white-space: nowrap;
}

.badge-default {
  background: rgba(255, 255, 255, 0.10);
  color: var(--color-text-secondary);
}

.badge-premium {
  background: var(--primitive-velvet-700);
  color: var(--primitive-velvet-200);
}

.badge-creator {
  background: var(--primitive-desire-500);
  color: white;
}

.badge-ai {
  background: var(--primitive-velvet-100);
  color: var(--primitive-velvet-700);
}

.badge-success {
  background: #D1FAE5;
  color: #065F46;
}

.badge-warning {
  background: #FEF3C7;
  color: #92400E;
}

.badge-danger {
  background: var(--primitive-desire-100);
  color: var(--primitive-desire-700);
}

.badge-novo {
  background: var(--primitive-desire-500);
  color: white;
  animation: pulse 2s var(--ease-standard) infinite;
}

/* ─────────────────────────────────────────────
   7. INPUTS / FORMULÁRIOS
   ───────────────────────────────────────────── */

.input-field {
  width: 100%;
  background: var(--color-bg-tertiary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-input);
  padding: 12px 16px;
  font-size: var(--text-sm);
  color: var(--color-text-primary);
  outline: none;
  transition:
    border-color var(--transition-fast),
    box-shadow var(--transition-fast);
}

.input-field::placeholder {
  color: var(--color-text-tertiary);
}

.input-field:focus {
  border-color: var(--color-border-focus);
  box-shadow: var(--focus-ring);
}

.input-field.erro {
  border-color: var(--primitive-desire-500);
}

.input-label {
  display: block;
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--color-text-secondary);
  margin-bottom: 6px;
}

.input-grupo {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon-left {
  position: absolute;
  left: 12px;
  color: var(--color-text-tertiary);
  pointer-events: none;
}

.input-icon-right {
  position: absolute;
  right: 12px;
  color: var(--color-text-tertiary);
  pointer-events: none;
}

.input-wrapper .input-field {
  padding-left: 40px;
}

.input-wrapper:has(.input-icon-right) .input-field {
  padding-right: 40px;
}

.input-erro-msg {
  font-size: var(--text-xs);
  color: var(--primitive-desire-400);
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 4px;
}

.input-hint {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  margin-top: 4px;
}

/* Toggle */
.toggle-label {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
}

.toggle-input {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

.toggle-track {
  position: relative;
  width: 44px;
  height: 24px;
  border-radius: var(--radius-full);
  background: var(--color-border-default);
  transition: background var(--transition-std);
  flex-shrink: 0;
}

.toggle-input:checked + .toggle-track {
  background: var(--color-brand-primary);
}

.toggle-track::after {
  content: '';
  position: absolute;
  top: 4px;
  left: 4px;
  width: 16px;
  height: 16px;
  border-radius: var(--radius-full);
  background: white;
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-std);
}

.toggle-input:checked + .toggle-track::after {
  transform: translateX(20px);
}

/* ─────────────────────────────────────────────
   8. CARDS
   ───────────────────────────────────────────── */

.card {
  background: var(--color-bg-tertiary);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-card);
  overflow: hidden;
}

.card-glass {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-card);
  overflow: hidden;
}

.card-elevated {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.card-interactive {
  background: var(--color-bg-tertiary);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-card);
  overflow: hidden;
  cursor: pointer;
  transition:
    transform var(--transition-fast),
    box-shadow var(--transition-fast),
    border-color var(--transition-fast);
}

.card-interactive:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
  border-color: var(--color-border-default);
}

.card-interactive:active {
  transform: translateY(0);
}

.card-velvet {
  background: var(--primitive-velvet-950);
  border: 1px solid var(--primitive-velvet-800);
  border-radius: var(--radius-card);
  overflow: hidden;
}

/* ─────────────────────────────────────────────
   9. NOTIFICAÇÃO DOT
   ───────────────────────────────────────────── */

.notif-dot-wrap {
  position: relative;
  display: inline-flex;
}

.notif-dot {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 20px;
  height: 20px;
  border-radius: var(--radius-full);
  background: var(--primitive-desire-500);
  color: white;
  font-size: 10px;
  font-weight: var(--weight-bold);
  display: none;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
  border: 2px solid var(--color-bg-primary);
}

.notif-dot.visivel {
  display: flex;
}

/* ─────────────────────────────────────────────
   10. PERFIL DO CRIADOR
   ───────────────────────────────────────────── */

.creator-hero {
  position: relative;
  overflow: hidden;
  min-height: 300px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.creator-hero-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.creator-hero-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(13, 11, 30, 0.95) 0%,
    rgba(13, 11, 30, 0.50) 50%,
    rgba(13, 11, 30, 0.10) 100%
  );
}

.creator-hero-content {
  position: relative;
  z-index: 10;
  padding: 0 16px 24px;
  margin-top: auto;
}

.creator-avatar-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 12px;
}

.creator-stats {
  display: flex;
  gap: 24px;
  text-align: center;
}

.creator-stat-valor {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  line-height: var(--leading-tight);
}

.creator-stat-label {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

.creator-acoes {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 16px;
}

/* Planos de assinatura */
.plano-card {
  background: var(--color-bg-tertiary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-card);
  padding: 20px;
  cursor: pointer;
  transition:
    border-color var(--transition-fast),
    background var(--transition-fast);
}

.plano-card.selecionado {
  border-color: var(--color-brand-primary);
  background: var(--primitive-velvet-950);
}

.plano-preco {
  font-size: var(--text-3xl);
  font-weight: var(--weight-bold);
  font-family: var(--font-display);
  line-height: var(--leading-tight);
}

.plano-feature {
  font-size: var(--text-sm);
  padding: 6px 0;
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--color-text-secondary);
}

/* ─────────────────────────────────────────────
   11. DM / CHAT
   ───────────────────────────────────────────── */

.dm-thread {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 16px;
  overflow-y: auto;
}

.dm-balao {
  max-width: 288px;
  padding: 10px 14px;
  font-size: var(--text-sm);
  line-height: var(--leading-relaxed);
}

.dm-balao-deles {
  background: var(--color-bg-tertiary);
  border-radius: 0 var(--radius-lg) var(--radius-lg) var(--radius-lg);
  align-self: flex-start;
}

.dm-balao-meu {
  background: var(--color-brand-primary);
  color: white;
  border-radius: var(--radius-lg) 0 var(--radius-lg) var(--radius-lg);
  align-self: flex-end;
}

.dm-tempo {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  text-align: center;
  padding: 8px 0;
}

.dm-status {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  align-self: flex-end;
  margin-top: -4px;
}

.dm-input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
  display: flex;
  gap: 8px;
  align-items: center;
  background: var(--color-bg-primary);
  border-top: 1px solid var(--color-border-subtle);
}

/* ── ──────────────────────────────────────────
   ALIASES — classes usadas no HTML
   (reconciliação HTML × CSS)
   ────────────────────────────────────────── */

/* Post Card — header do criador */
.post-card-creator {
  display: flex;
  align-items: center;
  gap: var(--space-4); /* era 12px — ring de 4px visual precisa de 16px para respirar */
  padding: 12px 16px;
}

.post-card-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.post-card-creator-name {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-card-creator-handle {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
}

/* Post Card — rodapé */
.post-card-footer {
  padding: var(--space-3) var(--space-4); /* era 10px 16px 12px — 10px é órfão fora dos tokens */
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.post-card-actions {
  display: flex;
  align-items: center;
  gap: 8px; /* era 2px — WCAG 2.2 mínimo 8px entre targets */
  flex-wrap: wrap;
}

.post-card-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 10px 12px; /* era 7px 10px — tap target ≥ 40px */
  border-radius: var(--radius-full);
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--color-text-secondary);
  transition: background var(--transition-fast), color var(--transition-fast);
  flex-shrink: 0;
  min-height: 40px;
}

.post-card-action-btn:hover {
  background: var(--color-bg-tertiary);
  color: var(--color-text-primary);
}

.action-icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

.post-card-action-btn--liked .action-icon,
.post-card-action-btn--liked {
  color: var(--primitive-desire-500);
}

.post-card-action-count {
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
}

/* Story — tamanho fixo e caption */
.story-ring {
  width: 62px;
  height: 62px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.story-avatar {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  box-sizing: border-box; /* border: 2px incluso nos 56px — não vaza pra fora do ring */
  overflow: hidden;       /* clipa o initials na forma circular */
  display: flex;
  align-items: center;
  justify-content: center;
}

.story-avatar-initials {
  width: 100%;
  height: 100%;
  min-width: unset;
  min-height: unset;
}

.story-ring--seen {
  background: var(--color-border-default);
}

.story-caption {
  font-size: 11px;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 68px; /* era 64px — alinhado à largura do .story-item (68px) */
  color: var(--color-text-secondary);
  line-height: 1.2;
}

/* Story item — evita quebra do label */
.story-item {
  flex-shrink: 0;
  width: 68px;
}

/* Bottom nav — tab criar (precisa de flex como os outros tabs) */
.bottom-nav-tab--criar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  min-width: 44px;
  font-size: 10px;
  font-weight: var(--weight-medium);
  color: var(--color-text-tertiary);
  background: none;
  border: none;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  position: relative;
}

/* Bottom nav — ícone circular */
.bottom-nav-create-btn {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, var(--primitive-desire-500) 0%, var(--primitive-desire-700) 100%);
  box-shadow: 0 4px 20px rgba(253, 41, 108, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  flex-shrink: 0;
}

